# ========================================
# 🎨 MEDIA FILES (optional - uncomment if needed)
# ========================================
# Uncomment these if you don't want to version media
# *.jpg
# *.jpeg
# *.png
# *.gif
# *.svg
# *.mp4
# *.mov
# *.avi
# *.mp3
# *.wav

# ========================================
# ✅ EXCEPTIONS (DO COMMIT THESE)
# ========================================
# Force-include certain files
!.gitkeep
!.env.example
!.vscode/settings.json.example
!Dockerfile
!docker-compose.yml
!requirements.txt
!README.md

# ========================================
# 🔍 DEBUGGING HELPERS
# ========================================
# If you accidentally commit secrets, use:
# git filter-branch --force --index-filter \
#   "git rm --cached --ignore-unmatch path/to/secret/file" \
#   --prune-empty --tag-name-filter cat -- --all
#
# Then force push: git push --force --all
# ========================================
