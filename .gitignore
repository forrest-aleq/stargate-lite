# Vim
*.swp
*.swo
*~
.vim/

# Emacs
*~
\#*\#
.\#*

# JetBrains (comprehensive)
.idea/
*.iml
*.ipr
*.iws
out/
.idea_modules/

# Eclipse
.project
.pydevproject
.settings/

