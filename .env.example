STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
# Optional — only needed for Stripe Connect OAuth
# STRIPE_CLIENT_ID=
# STRIPE_REDIRECT_URI=https://api.aleq.com/oauth/stripe/callback

# ─── Ramp (OAuth 2.0) ─────────────────────────────────────────────────────
