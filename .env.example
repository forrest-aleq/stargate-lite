# =============================================================================
# Stargate Lite — Production Environment Configuration
# =============================================================================
# Copy to .env and fill in your values:  cp .env.example .env
#
# Every variable the codebase reads via os.getenv() is listed here.
# Required vars have no default — the app will fail if they are missing.
# Optional vars show their default after the "=" sign.
#
# Auth types per service:
#   OAuth 2.0  — redirect-based, per-customer credentials stored in DB
#   API Key    — global key from env, shared across all requests
#   Session    — username/password exchanged for session token
#   Token-BA   — OAuth 1.0a token-based auth (NetSuite)
# =============================================================================

# =============================================================================
# CORE INFRASTRUCTURE (all required)
# =============================================================================

# ─── Server ─────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8001
DEBUG=false
ENVIRONMENT=production
API_SECRET_KEY=CHANGE_ME_STRONG_RANDOM_SECRET

# ─── CORS ───────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://console.aleq.com

# ─── Database ───────────────────────────────────────────────────────────────
# PostgreSQL required for production
DATABASE_URL=postgresql://user:password@host:5432/stargate_lite
# Supabase: use DIRECT connection (port 5432), not pooled (6543)
# DATABASE_URL=postgresql://postgres.[ref]:[pw]@aws-0-[region].pooler.supabase.com:5432/postgres
# SKIP_ALEMBIC=true  # Supabase manages migrations via CLI

# ─── Encryption ─────────────────────────────────────────────────────────────
# Fernet key — generated by setup.sh. DO NOT CHANGE once credentials are stored.
ENCRYPTION_KEY=CHANGE_ME_BASE64_FERNET_KEY

# ─── OAuth State Signing ────────────────────────────────────────────────────
# Optional — falls back to ENCRYPTION_KEY if not set
# OAUTH_STATE_SECRET=optional_separate_hmac_key

# ─── Frontend Redirect ─────────────────────────────────────────────────────
N3_FRONTEND_URL=https://console.aleq.com

# ─── Redis (required for idempotency + rate limiting + session cache) ──────
# Prefer REDIS_URL for managed Redis (Upstash, Railway, ElastiCache)
REDIS_URL=redis://default:password@host:6379
# Or use individual vars:
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_DB=0
# REDIS_PASSWORD=

# ─── Rate Limiting ──────────────────────────────────────────────────────────
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# ─── Sandboxed Code / Artifact Runtime (API Key) ───────────────────────────
# E2B powers long-lived sandboxes for code execution, file generation, and
# resumable background work inside Stargate. Official docs: https://e2b.dev/docs
E2B_API_KEY=

# =============================================================================
# OBSERVABILITY
# =============================================================================

# ─── Sentry (error tracking) ───────────────────────────────────────────────
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
RELEASE_VERSION=0.11.0
GIT_SHA=abc123

# ─── DataDog APM ───────────────────────────────────────────────────────────
DD_TRACE_ENABLED=true
DD_ENABLED=true
DD_ENV=production
DD_SERVICE=stargate-lite
DD_AGENT_HOST=localhost
DD_DOGSTATSD_PORT=8125

# ─── PostHog (product analytics) ───────────────────────────────────────────
POSTHOG_API_KEY=phc_your_posthog_project_key
POSTHOG_HOST=https://us.i.posthog.com
# POSTHOG_DEBUG=false

# ─── Logging ───────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# =============================================================================
# ACCOUNTING & ERP
# =============================================================================

# ─── QuickBooks Online (OAuth 2.0) ─────────────────────────────────────────
# Portal: https://developer.intuit.com/app/developer/dashboard
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
QUICKBOOKS_REDIRECT_URI=https://api.aleq.com/oauth/quickbooks/callback
QUICKBOOKS_ENVIRONMENT=production

# ─── Xero (OAuth 2.0) ─────────────────────────────────────────────────────
# Portal: https://developer.xero.com/app/manage
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
XERO_REDIRECT_URI=https://api.aleq.com/oauth/xero/callback

# ─── Zoho Books (OAuth 2.0) ───────────────────────────────────────────────
# Portal: https://api-console.zoho.com/
ZOHO_BOOKS_CLIENT_ID=
ZOHO_BOOKS_CLIENT_SECRET=
ZOHO_BOOKS_REDIRECT_URI=https://api.aleq.com/oauth/zoho_books/callback
# Optional: override accounts server by region (e.g., https://accounts.zoho.eu)
ZOHO_BOOKS_ACCOUNTS_SERVER=https://accounts.zoho.com
# Optional: API version override (default: v3)
ZOHO_BOOKS_API_VERSION=v3
# Optional: OAuth scopes override. Defaults to all module .ALL scopes from
# the generated OpenAPI manifest.
ZOHO_BOOKS_SCOPES=

# ─── NetSuite (Token-Based Auth / OAuth 2.0) ──────────────────────────────
# Portal: https://system.netsuite.com → Setup → Integration → Manage Integrations
NETSUITE_ACCOUNT_ID=
NETSUITE_CONSUMER_KEY=
NETSUITE_CONSUMER_SECRET=
NETSUITE_REDIRECT_URI=https://api.aleq.com/oauth/netsuite/callback

# ─── Bill.com (OAuth 2.0 + Dev Key) ───────────────────────────────────────
# Portal: https://developer.bill.com/ → My Apps
# OAuth for user auth, dev key for API access — both required
BILLCOM_CLIENT_ID=
BILLCOM_CLIENT_SECRET=
BILLCOM_REDIRECT_URI=https://api.aleq.com/oauth/billcom/callback
BILLCOM_DEV_KEY=
BILLCOM_ENVIRONMENT=production

# ─── Sage Intacct (Web Services) ──────────────────────────────────────────
# Portal: Sage Intacct → Company → Admin → Web Services
SAGE_INTACCT_CLIENT_ID=
SAGE_INTACCT_CLIENT_SECRET=
SAGE_INTACCT_SENDER_ID=
SAGE_INTACCT_SENDER_PASSWORD=

# =============================================================================
# PAYMENTS & FINANCE
# =============================================================================

