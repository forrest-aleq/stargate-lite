# =============================================================================
# SERVICE GATE — Controls what N3 shows on the integrations page
# =============================================================================
# Comma-separated list of service names. Only these appear in /health/connectors.
# If not set, defaults to: quickbooks
ENABLED_SERVICES=quickbooks,xero,zoho_books,stripe,hubspot,slack
